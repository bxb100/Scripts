{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "immich-share",
	"main": "src/index.js",
	"compatibility_date": "2026-07-17",
	"observability": {
		"enabled": false,
	},
	"preview_urls": false,
	"upload_source_maps": true,
	"placement": {
		"mode": "smart",
	},
	"cache": {
		"enabled": true,
	},
	"vpc_networks": [
		{
			"binding": "NAS",
			"tunnel_id": "f12f3b2a-db4c-4a55-bb05-016135e09a8b",
			"remote": true,
		},
	],
}
